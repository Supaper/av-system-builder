{
  "permissions": {
    "allow": [
      "mcp__github__get_file_contents",
      "mcp__github__list_branches",
      "mcp__github__list_releases",
      "PowerShell(git add *)",
      "PowerShell(git commit *)",
      "PowerShell(git push *)",
      "PowerShell(npm run build)",
      "PowerShell(npm run dev)",
      "WebFetch(domain:claude.ai)",
      "Bash(gh --version)",
      "Bash(mkdir -p \"c:/Users/tnwhd/OneDrive/바탕 화면/Gusung/.claude/commands\")",
      "PowerShell($env:PATH += \";C:\\\\Program Files\\\\Git\\\\bin;C:\\\\Program Files\\\\Git\\\\cmd\"; git branch --show-current)",
      "PowerShell($env:PATH += \";C:\\\\Program Files\\\\Git\\\\bin;C:\\\\Program Files\\\\Git\\\\cmd\"; git status)",
      "PowerShell($env:PATH += \";C:\\\\Program Files\\\\Git\\\\bin;C:\\\\Program Files\\\\Git\\\\cmd\"; git diff .claude/settings.json)",
      "PowerShell($env:PATH += \";C:\\\\Program Files\\\\Git\\\\bin;C:\\\\Program Files\\\\Git\\\\cmd\"; git log --oneline -5)"
    ],
    "additionalDirectories": [
      "c:\\Users\\tnwhd\\OneDrive\\바탕 화면\\Gusung\\.claude"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$env:PATH += ';C:\\Program Files\\Git\\bin;C:\\Program Files\\Git\\cmd'; [Console]::OutputEncoding = [System.Text.Encoding]::UTF8; git fetch origin 2>&1 | Out-Null; $s = (git status 2>&1 | Out-String).Trim(); $l = (git log --oneline -5 2>&1 | Out-String).Trim(); $ctx = \"[Session Start] Git Status:`n\" + $s + \"`n`n[Recent Commits]`n\" + $l; @{hookSpecificOutput=@{hookEventName='SessionStart';additionalContext=$ctx}} | ConvertTo-Json -Compress -Depth 3",
            "shell": "powershell",
            "timeout": 30,
            "statusMessage": "git 상태 확인 중..."
          }
        ]
      }
    ]
  }
}
