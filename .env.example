# Firebase 클라우드 공유 설정 (선택)
#
# src/firebaseConfig.ts 에 값을 직접 넣는 대신 환경변수로 주입하고 싶을 때 사용한다.
# 이 파일을 .env.local 로 복사한 뒤 값을 채운다. (.env.local 은 git에 커밋되지 않는다.)
#
# ⚠️ GitHub Pages 자동 배포(Actions)는 이 .env 값을 읽지 못한다.
#    배포본에도 공유 기능을 쓰려면 src/firebaseConfig.ts 에 직접 값을 넣는 것이 가장 간단하다.
#    (Firebase 웹 설정값은 공개되어도 되는 값이며, 보안은 Firestore 규칙으로 처리한다.)

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
